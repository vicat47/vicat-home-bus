# HomeBus 主配置文件示例
# 复制到 ~/.config/homebus/config.toml 并修改
# 优先级: 默认值 < config.toml < 环境变量 < CLI 参数

[homebus.api]
host = "0.0.0.0"
port = 8080
debug = false

[homebus.database]
path = "~/.local/share/homebus/data.db"

[adapters.grocy]
base_url = "http://localhost:9283"
# api_key 通过环境变量 GROCY_API_KEY 注入

[adapters.beancount]
mode = "fava"
ledger_path = "~/ledger"
fava_url = "http://localhost:5000"

[adapters.homebox]
base_url = "http://localhost:7745"
# token 通过环境变量 HOMEBOX_TOKEN 注入

[cli]
api_url = "http://localhost:8080"
timeout = 30
